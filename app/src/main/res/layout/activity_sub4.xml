<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sub4_"
    android:orientation="vertical"
    tools:context=".SubActivity4">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animation_view4"
        android:layout_width="250dp"
        android:layout_height="300dp"
        android:layout_marginLeft="340dp"
        android:layout_marginTop="620dp"
        android:layout_marginBottom="20dp"
        android:background="@color/white"
        app:lottie_autoPlay="true"
        app:lottie_fileName="sub4.json"
        app:lottie_loop="true" />

    <ImageView
        android:id="@+id/txt"
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:src="@drawable/sibal12"
        android:layout_marginLeft="-30dp"
        android:layout_marginTop="-1130dp"/>

    <Button
        android:id="@+id/btn"
        android:text="움직임 확인"
        android:fontFamily="@font/hanna"
        android:textColor="@color/black"
        android:layout_marginTop="-300dp"
        android:layout_marginLeft="250dp"
        android:backgroundTint="@color/blue2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>